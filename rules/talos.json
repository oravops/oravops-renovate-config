{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Limit Talos versions to avoid breaking changes",
  "packageRules": [
    {
      "extends": ["github>oravops/oravops-renovate-config//packages/talos#3.0.1"],
      "allowedVersions": "!/^\\d+\\.\\d+\\.0$/",
      "separateMultipleMinor": true,
      "separateMinorPatch": true
    }
  ]
}
